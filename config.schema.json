{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Keybearer config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profiles"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9._-]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codex": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "opencode": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "claudeCode": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "providerKind",
        "apiKey",
        "apps"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "providerKind": {
          "enum": [
            "openai",
            "anthropic",
            "openai-compatible"
          ]
        },
        "apiKey": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1
        },
        "apps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "codex",
              "opencode",
              "claudeCode"
            ]
          }
        },
        "appConfig": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "codex": {
              "$ref": "#/$defs/codexModels"
            },
            "opencode": {
              "$ref": "#/$defs/opencodeModels"
            },
            "claudeCode": {
              "$ref": "#/$defs/claudeCodeModels"
            }
          }
        },
        "meta": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "providerKind": {
                "const": "anthropic"
              }
            }
          },
          "then": {
            "properties": {
              "apps": {
                "items": {
                  "enum": [
                    "opencode",
                    "claudeCode"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "providerKind": {
                "enum": [
                  "openai",
                  "openai-compatible"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "apps": {
                "items": {
                  "enum": [
                    "codex",
                    "opencode"
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "providerKind": {
                "const": "openai"
              }
            }
          },
          "then": {
            "properties": {
              "apps": {
                "items": {
                  "enum": [
                    "codex",
                    "opencode"
                  ]
                }
              }
            }
          }
        }
      ]
    },
    "codexModels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoningEffort": {
          "enum": [
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "high"
        },
        "disableResponseStorage": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "opencodeModels": {
      "description": "OpenCode ProviderConfig passthrough. See https://opencode.ai/config.json",
      "type": "object",
      "properties": {
        "npm": {
          "type": "string"
        },
        "api": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "options": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string"
            },
            "baseURL": {
              "type": "string"
            },
            "setCacheKey": {
              "type": "boolean"
            },
            "timeout": {
              "type": "integer"
            },
            "headerTimeout": {
              "type": "integer"
            },
            "chunkTimeout": {
              "type": "integer"
            }
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "family": {
                "type": "string"
              },
              "attachment": {
                "type": "boolean"
              },
              "reasoning": {
                "type": "boolean"
              },
              "temperature": {
                "type": "boolean"
              },
              "tool_call": {
                "type": "boolean"
              },
              "experimental": {
                "type": "boolean"
              },
              "status": {
                "enum": [
                  "alpha",
                  "beta",
                  "deprecated",
                  "active"
                ]
              },
              "cost": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  },
                  "cache_read": {
                    "type": "number"
                  },
                  "cache_write": {
                    "type": "number"
                  }
                }
              },
              "limit": {
                "type": "object",
                "properties": {
                  "context": {
                    "type": "number"
                  },
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  }
                }
              },
              "modalities": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "array",
                    "items": {
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  },
                  "output": {
                    "type": "array",
                    "items": {
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  }
                }
              },
              "variants": {
                "type": "object",
                "additionalProperties": {
                  "type": "object"
                }
              },
              "options": {
                "type": "object"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "whitelist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blacklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "claudeCodeModels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "haikuModel": {
          "type": "string",
          "minLength": 1
        },
        "sonnetModel": {
          "type": "string",
          "minLength": 1
        },
        "opusModel": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
