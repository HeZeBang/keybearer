{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Keybearer config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profiles"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]+$" },
      "additionalProperties": { "$ref": "#/$defs/profile" }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codex": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
        "opencode": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" }
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "providerKind", "apiKey", "apps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "providerKind": { "enum": ["openai", "anthropic", "openai-compatible"] },
        "apiKey": { "type": "string", "minLength": 1 },
        "baseUrl": { "type": "string", "minLength": 1 },
        "apps": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["codex", "opencode"] }
        },
        "models": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "codex": { "$ref": "#/$defs/codexModels" },
            "opencode": { "$ref": "#/$defs/opencodeModels" }
          }
        },
        "meta": { "type": "object" }
      }
    },
    "codexModels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "models": { "$ref": "#/$defs/stringList" },
        "reasoningEffort": { "type": "string", "minLength": 1 }
      }
    },
    "opencodeModels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "models": { "$ref": "#/$defs/stringList" }
      }
    },
    "stringList": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      ]
    }
  }
}
